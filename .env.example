# Stigmergic Exponential Economist — Environment Configuration

# Agent identity (use a unique seed for production)
AGENT_NAME=stigmergic-exponential-economist
AGENT_SEED_PHRASE=your_unique_seed_phrase_here
AGENT_PORT=8002

# LLM Configuration (ASI:One recommended for Agentverse)
ASI_ONE_API_KEY=your_asi_one_api_key
# Alternative: OPENAI_API_KEY=your_openai_api_key

# Optional LLM overrides
LLM_BASE_URL=https://api.asi1.ai/v1
LLM_MODEL=asi1

# Optional: live data grounding API (Phase 2+)
# DATA_GROUNDING_API_URL=https://your-data-api.example.com/metrics